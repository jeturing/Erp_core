# ═══════════════════════════════════════════════════════
# ERP Core — Environment Configuration Template
# Copy to .env and fill in real values
# NEVER commit .env with real credentials to git
# ═══════════════════════════════════════════════════════

# ── Database ──
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/erp_core_db
DB_USER=
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=erp_core_db

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── JWT / Auth ──
JWT_SECRET_KEY=generate-a-strong-random-secret
JWT_REFRESH_SECRET_KEY=generate-another-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ADMIN_USERNAME=admin@example.com
ADMIN_PASSWORD=change-me

# ── Odoo ──
ODOO_DEFAULT_ADMIN_LOGIN=admin@example.com
ODOO_DEFAULT_ADMIN_PASSWORD=change-me
ODOO_MASTER_PASSWORD=change-me
ODOO_DB_USER=odoo
ODOO_DB_PASSWORD=change-me
ODOO_DEFAULT_LANG=es_DO
ODOO_DEFAULT_COUNTRY=DO
ODOO_BASE_DOMAIN=example.com
ODOO_TEMPLATE_DB=template_tenant

# ── Infrastructure ──
ODOO_PRIMARY_IP=10.10.10.100
ODOO_PRIMARY_PCT_ID=105
ODOO_PRIMARY_PORT=8069
ODOO_PRIMARY_API_PORT=8070
ERP_CORE_IP=10.10.10.20
CT105_IP=10.10.10.100
CT105_NGINX_PORT=8080

# ── Cloudflare ──
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_TUNNEL_ID=your-tunnel-uuid
CLOUDFLARE_ZONES=example.com=zone-id-here

# ── Provisioning ──
PROVISIONING_API_KEY=generate-a-secure-key

# ── Application ──
APP_URL=http://localhost:4443
ENVIRONMENT=development
FORCE_HTTPS=false
ENABLE_WAF=true
API_KEY_SECRET=change-me
