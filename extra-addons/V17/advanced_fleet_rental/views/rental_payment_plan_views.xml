<odoo>
    <!--Tree View of Rental Payment Plan-->
    <record id="rental_payment_plan_view_tree" model="ir.ui.view">
        <field name="name">rental.payment.plan.view.tree</field>
        <field name="model">rental.payment.plan</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree string="car_contract_result">
                <field name="contract_id"/>
            </tree>
        </field>
    </record>
    <!--Action View of Rental Payment Plan -->
    <record id="action_rental_payment_plan" model="ir.actions.act_window">
        <field name="name">Rental Payment Plan</field>
        <field name="res_model">rental.payment.plan</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>