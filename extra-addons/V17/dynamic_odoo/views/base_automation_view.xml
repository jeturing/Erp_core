<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="dynamic_odoo_base_automation" model="ir.ui.view">
            <field name="name">dynamic_odoo.base.automation</field>
            <field name="model">base.automation</field>
            <field name="inherit_id" ref="base_automation.view_base_automation_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='trigger']" position="attributes">
                    <attribute name="widget">selection</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
