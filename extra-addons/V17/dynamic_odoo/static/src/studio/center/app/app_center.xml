<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.AppCenter.Wellcome">
        <div class="info_creator" step="step0">
            <div class="info_con">
                <h2>Welcome to</h2>
                <h1>Odoo Studio</h1>
                <h5>The fastest way to create a web application.</h5>
            </div>
            <div class="infor_foot">
                <a class="btn btn-primary next" t-on-click="() => this.flowStep.bind(this)()">Next <i
                        class="oi oi-chevron-right"/></a>
            </div>
        </div>
    </t>

    <t t-name="dynamic_odoo.widget.ColorPicker">
        <div class="color_picker_widget">
            <span class="picker_item dropdown-toggle o-no-caret" data-bs-toggle="dropdown">
                <t t-if="props.icon">
                    <i t-att-class="props.icon"/>
                </t>
                <t t-else="">
                    <span class="color_shower" t-att-style="'background-color:'+state.value"></span>
                </t>
            </span>
            <ul class="dropdown-menu colorpicker-menu">
                <t t-component="ColorPalette" t-props="colorPaletteProps"/>
            </ul>
        </div>
    </t>

    <t t-name="dynamic_odoo.AppCenter.Icons">
        <div class="icon_creator">
            <div class="ic_container">
                <h5 t-if="props.editable and !state.image">Design your Icon</h5>
                <div class="icon_area">
                    <div class="ic_preview"
                         t-att-style="'background:' + (state.image ? 'url('+state.image+')' : state.bgColor) + '; background-size: cover'">
                        <i t-if="!state.image" t-att-class="state.icon" t-att-style="'color:' + state.color"/>
                    </div>
                    <div class="ic_modifier" t-if="props.editable and !state.image">
                        <ColorPicker value="state.bgColor" update="(value) => state.bgColor = value"/>
                        <ColorPicker value="state.color" update="(value) => state.color = value"/>
                        <div t-on-click="onShowIconDialog" class="icon_modifier">
                            <i t-att-class="state.icon"/>
                        </div>
                    </div>
                </div>
                <a t-if="props.editable" class="upload_ic"><span t-on-click="onShowIconDialog" t-if="state.image">Design your Icon </span> or <span t-on-click="onUploadIcon"><t t-esc="state.image ? 'upload one' : 'upload it'" /></span></a>
            </div>
        </div>
    </t>

    <t t-name="dynamic_odoo.AppCenter.AppInfo">
        <div class="info_creator">
            <div class="info_title">
                <h2><t t-esc="currentStep.title" /></h2>
            </div>
            <div class="info_con">
                <div class="info_modifier">
                    <t t-foreach="state.views" t-as="fieldName" t-key="Math.random()">
                        <Field t-props="getProps({...fields[fieldName], name: fieldName})"/>
                    </t>
                </div>
            </div>
            <div class="infor_foot">
                <a class="prev" t-on-click="() => this.flowStep.bind(this)('prev')"><i class="oi oi-chevron-left" /></a>
                <a t-att-class="state.canNext ? 'next' : 'next disable'" t-on-click="() => state.canNext &amp;&amp; this.flowStep.bind(this)()"><i class="oi oi-chevron-right" /></a>
            </div>
        </div>
    </t>

    <t t-name="dynamic_odoo.AppCenter">
        <div class="app_center">
            <div></div>
            <div class="s_app_container">
                <div class="s_creator">
                    <t t-if="state.step == 'step0'">
                        <t t-call="dynamic_odoo.AppCenter.Wellcome"/>
                    </t>
                    <t t-else="">
                        <t t-call="dynamic_odoo.AppCenter.AppInfo"/>
                    </t>
                    <IconCreator editable="currentStep.editable"/>
                </div>
            </div>
        </div>
    </t>
</templates>