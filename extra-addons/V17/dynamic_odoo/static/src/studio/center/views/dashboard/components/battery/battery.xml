<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.Battery.layout_1" owl="1">
        <battery>
            <div class="battery_widget">
                <div class="battery_details">
                    <div class="w_meter">
                        <div class="w_percen">
                            <t t-foreach="Object.keys(groups)" t-as="groupName" t-key="Math.random()">
                                <t t-set="group" t-value="groups[groupName]"/>
                                <div t-on-click="() => onShowInfo.bind(this)(group)"
                                     t-att-style="'background-color:' + group.color + ';' + 'width:' + group.percen+'%';">
                                </div>
                            </t>
                        </div>
                        <div class="w_charge"></div>
                    </div>
                    <div class="w_info">
                        <h3><t t-esc="info" /></h3>
                    </div>
                </div>
                <div class="battery_info">
                    <t t-foreach="Object.keys(groups)" t-as="groupName" t-key="Math.random()">
                        <t t-set="group" t-value="groups[groupName]"/>
                        <div class="item" t-on-click="() => onShowInfo.bind(this)(group)">
                            <div t-att-class="state.active == groupName ? 'battery_color active' : 'battery_color'">
                                <span t-att-style="'background-color:' + group.color"></span>
                            </div>
                            <span class="battery_label"><t t-esc="group.label" /></span>
                        </div>
                    </t>
                </div>
            </div>
        </battery>
    </t>
</templates>