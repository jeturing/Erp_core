<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.ViewCenter.SwitchView">
        <div class="views_ctrl" t-ref="views_ctrl">
            <t t-set="viewsExist" t-value="props.action.views.map((view) => view[1])"/>
            <t t-set="notExist"
               t-value="Object.keys(viewsCtrl).filter((viewType) => !viewsExist.includes(viewType))"/>
            <t t-set="views_ctrl" t-value="viewsExist.concat(notExist)"/>
            <t t-foreach="views_ctrl" t-as="viewType" t-key="'view_ctrl_'+viewType">
                <a t-if="viewsCtrl[viewType]" t-att-name="viewType"
                   t-attf-class="#{viewsCtrl[viewType].icon}#{viewType == props.viewType ? ' active' : ''}#{notExist.includes(viewType) ? ' no_exist' : ''}"
                   t-att-data-tooltip="viewsCtrl[viewType].label"
                   t-on-click="() => this.switchView(viewType, !viewsExist.includes(viewType))"></a>
            </t>
        </div>
    </t>
    <t t-name="dynamic_odoo.ViewCenter">
        <div t-if="!state.stacks[0].viewInfo" class="no_support">
            <div>
                <h3>We don't support edit this view !!!</h3>
            </div>
        </div>
        <div t-else="" class="view_center" t-att-view_type="state.viewType">
            <div class="vc_head">
                <div>
                    <i class="fa fa-cog edit_action" t-on-click="onShowAction" data-tooltip="Edit Action"></i>
                    <div class="view_tree_ctrl">
                        <t t-foreach="state.stacks" t-as="stack" t-key="'stack_view_tree_ctrl' + stack.key">
                            <a t-on-click="() => onBackView.bind(this)(stack_index+1)"><t t-esc="stack.viewInfo.string" /></a>
                            <t t-if="state.stacks.length > 1 and state.stacks.length > (stack_index+1)">
                                <i class="fa fa-angle-right"/>
                            </t>
                        </t>
                    </div>
                </div>
                <div class="undo_redo_view">
                    <a t-attf-class="#{currentStack.undo ? 'can_undo' : ''} btn undo_report" data-tooltip="Undo View (We support 3 undo saves of previous changes)" t-on-click.prevent="() => onUndoRedo.bind(this)('undo')"><i class="fa fa-undo" /></a>
                    <a t-attf-class="#{currentStack.redo ? 'can_redo' : ''} btn redo_report" data-tooltip="Redo View" t-on-click.prevent="() => onUndoRedo.bind(this)('redo')"><i class="fa fa-repeat" /></a>
                </div>
                <div class="modifier_ctrl">
                    <div></div>
                    <SwitchView model="model" action="action" viewType="state.viewType" onChange.bind="onChangeView"/>
                </div>
            </div>
            <div class="vc_con" t-ref="stacks">
                <t t-foreach="state.stacks" t-as="stack" t-key="stack.key">
                    <div class="stack_wrap">
                        <t t-component="modifierRegistry.get(stack.viewInfo.viewType)"
                           setComponent="(component) => setComponent.bind(this)(stack, component)" t-props="stack"/>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>