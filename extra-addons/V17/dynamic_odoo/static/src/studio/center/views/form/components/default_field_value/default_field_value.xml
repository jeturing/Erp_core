<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.DefaultFieldValue">
        <div class="default_field_value">
            <t t-set="_prepareField" t-value="prepareField"/>
            <t t-component="_prepareField.component" t-props="_prepareField.props()" value="json_value"
               update="(value) => props.update(_prepareField.formatValue(value))"/>
        </div>
    </t>

</templates>
