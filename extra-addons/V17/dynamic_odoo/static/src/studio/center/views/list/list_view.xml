<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.ListView" owl="1">
        <div t-att-class="className" t-ref="root">
            <t t-component="props.Renderer"
               list="model.root"
               activeActions="activeActions"
               archInfo="archInfo"
               allowSelectors="props.allowSelectors"
               editable="editable"
               onOpenFormView="onOpenFormView"
               openRecord.bind="openRecord"
               noContentHelp="props.info.noContentHelp"
               onAdd.bind="createRecord"
               onOptionalFieldsChanged.bind="onOptionalFieldsChanged"
               evalViewModifier.bind="evalViewModifier"
            />
        </div>
    </t>

    <t t-name="dynamic_odoo.ListRenderer" t-inherit="web.ListRenderer" t-inherit-mode="primary" owl="1">
        <xpath expr="//table" position="attributes">
            <attribute name="t-att-node-id">treeNodeId</attribute>
        </xpath>
        <xpath expr="//th[@t-att-data-name]" position="attributes">
            <attribute name="t-att-node-id">column.attrs['node-id']</attribute>
        </xpath>
<!--        <xpath expr="//tbody/t" position="before">-->
<!--            <tr class="tr_search_in_tree" t-if="props.archInfo.searchInTree">-->
<!--                <td t-if="hasSelectors" class="th_search"></td>-->
<!--                <t t-foreach="state.columns" t-as="column" t-key="'search_in_tree_' +column.name">-->
<!--                    <td class="th_search">-->
<!--                        <SearchInTree field="props.list.fields[column.name]"/>-->
<!--                    </td>-->
<!--                </t>-->
<!--                <td t-if="displayOptionalFields or activeActions.onDelete" class="th_search"></td>-->
<!--            </tr>-->
<!--        </xpath>-->
    </t>
    <t t-name="dynamic_odoo.ListRenderer.Rows" t-inherit="web.ListRenderer.Rows" t-inherit-mode="primary">
        <xpath expr="//tr[@t-foreach='getEmptyRowIds']" position="replace">
            <t t-if="!list.records.length" t-foreach="[1, 2, 3, 4, 5]" t-key="Math.random()">
                <tr>
                    <td t-if="hasSelectors" class="o_list_record_selector user-select-none"></td>
                    <t t-foreach="getColumns(record)" t-as="column" t-key="column.id">
                        <td>&#8203;</td>
                    </t>
                </tr>
            </t>
        </xpath>
    </t>
    <t t-name="List.TabField" owl="1">
        <div class="tab_fields">
            <div class="search_field">
                <Field t-props="{type: 'char', props: {placeholder: 'Search field...', update: this.onSearch.bind(this)}}"/>
            </div>
            <div class="fields_result st_scroll">
                <t t-foreach="props.fields" t-as="field" t-key="field.name">
                    <t t-if="!props.without_fields.includes(field.name) and (field.field_description.includes(state.search) || !state.search)">
                        <DragField t-props="{title: field.field_description, name: field.name}"/>
                    </t>
                </t>
            </div>
        </div>
    </t>

    <t t-name="dynamic_odoo.List.View.default" owl="1">
        <tree string="Studio Tree">
            <field name="id"/>
        </tree>
    </t>

</templates>
