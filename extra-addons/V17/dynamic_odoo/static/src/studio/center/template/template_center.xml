<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.TemplateCenter" owl="1">
        <div class="template_center" t-att-class="constructor.classes">
            <div class="undo_redo_view">
                <a t-attf-class="#{canUndoRedo.can_undo ? 'can_undo' : ''} btn undo_report"
                   t-on-click.prevent="() => onUndoRedo.bind(this)('undo')"
                   data-tooltip="Undo View (We support 3 undo saves of previous changes)"><i class="fa fa-undo" /></a>
                <a t-attf-class="#{canUndoRedo.can_redo ? 'can_redo' : ''} btn redo_report"
                   t-on-click.prevent="() => onUndoRedo.bind(this)('redo')" data-tooltip="Redo View"><i class="fa fa-repeat" /></a>
            </div>
            <Modifier model="model" reloadReport.bind="reload" viewInfo="viewInfo"/>
        </div>
    </t>
</templates>