<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.Widget.Tab" owl="1">
        <div class="so_mb_widget_tab">
            <div class="tab_header">
                <t t-foreach="Object.keys(props.options)" t-as="optionName" t-key="optionName">
                    <a t-att-name="optionName" t-att-class="state.active == optionName ? 'tab_item active' : 'tab_item'"
                       t-on-click="() => this.onChangeTab(optionName)">
                        <t t-esc="props.options[optionName].label"/>
                    </a>
                </t>
            </div>
            <div class="tab_container st_scroll" t-att-name="state.active" t-if="state.matrix">
                <t t-foreach="props.options[state.active].content" t-as="com"
                   t-key="'component_' + state.active + '_' + Math.random()">
<!--                   t-key="'component_' + state.active + '_' + com_index">-->
                    <t t-if="typeof com == 'string'">
                        <t t-call="{{com}}"/>
                    </t>
                    <t t-else="">
                        <t t-component="com.component" t-props="com.props"/>
                    </t>
                </t>
            </div>
        </div>
    </t>
</templates>