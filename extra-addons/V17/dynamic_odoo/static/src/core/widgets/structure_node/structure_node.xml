<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.widgets.structure_node" owl="1">
        <div class="structure_node">
<!--            <CodeEditor-->
            <!--                    value="structureNodeString"-->
            <!--                    mode="'xml'"-->
            <!--                    class="'ace-view-editor'"-->
            <!--                    maxLines="200"-->
            <!--                    theme="'monokai'"-->
            <!--            />-->
            <a t-if="props.useCodeEditor" class="show_code_editor" t-on-click="onShowCodeEdit"><i class="fa fa-code me-2"></i>Edit source</a>
            <div>
                <t t-set="_structure" t-value="getStructure()"/>
                <div t-if="_structure.length > 1" class="structure_head">
                    <t t-foreach="_structure" t-as="node" t-key="'structure' + node_index">
                        <div class="line_node">
                            <span class="line_x"></span>
                            <h5 t-on-click="() => props.onChangeNode(node)">
                                <i class="fa fa-cog"/>
                                <t t-esc="node.tag"/>
                                <span class="sp_attr">
                                    <t t-esc="getAttrsShow(node)"/>
                                </span>
                            </h5>
                            <span class="line_y"></span>
                        </div>
                    </t>
                </div>
                <div t-att-class="'structure_con ' + (_structure.length > 1 ? 'line_border' : '')">
                    <t t-set="_nodeModifier" t-value="getNodeModifier()"/>
                    <t t-foreach="Object.keys(_nodeModifier.fields || {})" t-as="fieldName"
                       t-key="fieldName + '_key_' + fieldName_index">
                        <Field t-props="{..._nodeModifier.fields[fieldName], name: fieldName}"/>
                    </t>
                </div>
            </div>
        </div>
    </t>
</templates>
