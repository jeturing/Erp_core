<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.Many2manyField" owl="1">
        <div class="many2many_field">
            <div class="w_tags" t-if="state.value.length">
                <t t-foreach="state.value" t-as="val" t-key="val">
                    <span class="st_tag" t-att-name="val"><t t-esc="valueInfo[val].display_name" />
                        <i class="fa fa-close" t-on-click="() => onCloseTag.bind(this)(val)"/></span>
                </t>
            </div>
            <div t-ref="many2manyTagsField">
                <StudioMany2ManyTagsField t-props="m2mProps"/>
            </div>
        </div>
    </t>

</templates>
