<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.ChooseIconWidget" owl="1">
        <div class="choose_icon_widget">
            <div class="icon_search">
                <CharField update="(value) => state.value = value" />
            </div>
            <div class="icon_result">
                <div class="icons_con">
                    <t t-foreach="state.value ? [state.value] : IconsDefault" t-as="icon" t-key="icon">
                        <a class="icon" t-on-click="() => props.update(icon)">
                            <i t-att-class="'fa fa-'+icon" />
                        </a>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>
