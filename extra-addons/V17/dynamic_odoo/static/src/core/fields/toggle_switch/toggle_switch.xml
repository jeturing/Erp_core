<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.Field.ToggleSwitch" owl="1">
        <div class="toggle_switch_widget">
            <label class="switch">
                <t t-if="state.value">
                    <input type="checkbox" checked="" t-on-change="onChangeInput" />
                </t>
                <t t-else="">
                    <input type="checkbox" t-on-change="onChangeInput" />
                </t>
                <span class="slider round"></span>
            </label>
            <div t-if="!props.hideLabel">
                <a class="field_label"><t t-esc="props.label || 'Toggle Switch'" /></a>
            </div>
        </div>
    </t>

</templates>
