<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="odoo_menu_management.MenuUi" owl="1">
        <div class="o_widget_omm">
            <div class="omm_view">
                <div class="omm_screen" t-if="state.menus and state.helps">
                    <div class="omm_screen_search">
                        <div class="input-group input-group-sm omm_filters">
                            <button id="omm_filters" data-bs-toggle="dropdown" class="btn btn-secondary btn-sm dropdown-toggle">
                                <t t-esc="this.filterName"/>
                            </button>
                            <div class="dropdown-menu">
                                <t t-foreach="state.filterInputs" t-as="option" t-key="option.id" aria-labelledby="omm_filters">
                                    <a t-attf-class="dropdown-item#{state.filerIn == option.id and ' active' or ''}" t-on-click="() => this._onSelectFilter(option.id,option.name,option.domain)">
                                        <span t-out="option.name"/>
                                    </a>
                                </t>
                            </div>
                        </div>
                        <div class="input-group input-group-sm omm_search">
                            <button type="button" class="btn btn-secondary dropdown-toggle" data-bs-toggle="dropdown"/>
                            <div class="dropdown-menu" role="menu">
                                <t t-foreach="state.searchbarInputs" t-as="input" t-key="input_index">
                                    <a t-attf-class="dropdown-item#{state.searchIn == input.id and ' active' or ''}" t-on-click="() => this._onSelectSearch(input.id)">
                                        <span t-out="input.name"/>
                                    </a>
                                </t>
                            </div>
                            <input type="text" class="form-control form-control-sm" placeholder="Search" id="omm_search_input" t-att-value="state.searchInput" t-on-keyup="(event) => this._onSearchkeyUp(event)"/>
                            <button class="btn btn-secondary" t-on-click="() => this._onExecuteSearch()">
                                <span class="fa fa-search"/>
                            </button>
                            <button class="btn btn-secondary" t-on-click="() => this._onClearSearch()">
                                <span class="fa fa-ban"/>
                            </button>
                        </div>
                    </div>
                    <div class="omm_screen_header">
                        <div class="omm_title">Menu</div>
                        <div class="omm_global_hide text-center" t-att-title="state.helps[0]">Hide for everyone</div>
                        <div class="omm_setting" t-att-title="state.helps[1]">Hide for users (global)</div>
                        <div class="omm_setting" t-att-title="state.helps[2]">Hide for users (personal)</div>
                        <div class="omm_setting" t-att-title="state.helps[3]">Show only for users</div>
                        <div class="omm_setting" t-att-title="state.helps[4]">Hide for companies</div>
                        <div class="omm_setting" t-att-title="state.helps[5]">Show only for companies</div>
                        <div class="omm_setting" t-att-title="state.helps[6]">Show only for groups</div>
                    </div>
                    <t t-foreach="state.menus" t-as="oMenu" t-key="oMenu.id">
                        <OMMItem oMenu="oMenu" helps="state.helps"/>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>
