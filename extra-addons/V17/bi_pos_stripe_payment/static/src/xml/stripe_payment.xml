<?xml version="1.0" encoding="UTF-8"?>

<templates id="pos_stripe_payment_template" inherit_id="point_of_sale.template" xml:space="preserve">

    <t t-name="bi_pos_stripe_payment.PaymentScreenPaymentLines" t-inherit="point_of_sale.PaymentScreenPaymentLines" t-inherit-mode="extension" owl="1">

        <xpath expr="//div[hasclass('paymentline')]" position="replace">
            <t t-if="line.is_stripe">
                <div class="paymentline selected d-flex align-items-center" style="background-color:orange"
                     t-att-class="selectedLineClass(line)">
                     <div class="payment-infos d-flex align-items-center justify-content-between flex-grow-1 px-3 py-4 my-2 text-truncate cursor-pointer" t-on-click="() => this.selectLine(line)">
                         <span class="payment-name"><t t-esc="line.payment_method.name"/></span>
                         <div class="payment-amount px-3">
                            <t t-if="line and line.payment_status and ['done', 'waitingCard', 'waiting', 'reversing', 'reversed'].includes(line.payment_status)">
                                    <t t-esc="env.utils.formatCurrency(line.get_amount(), false)" />
                            </t>
                            <t t-else="">
                                    <t t-esc="formatLineAmount(line)" />
                            </t>
                        </div>
                    </div>
                    <t t-if="!line.payment_status or !['done', 'reversed', 'waitingCard', 'waitingCapture'].includes(line.payment_status)">
                        <button class="delete-button btn btn-link mx-2 px-3"
                            t-on-click="() => this.props.deleteLine(line.cid)"
                            aria-label="Delete" title="Delete">
                            <i class="fa fa-2x fa-times-circle" />
                        </button>
                    </t>

                    <div class="refresh-button" data-cid="c60">
                        <i style="font-size:20px;color:white" class="fa fa-refresh fa-3x fa-fw fa-spin"></i>
                    </div>
                </div>
            </t>
            <t t-else="">
                <div class="paymentline selected d-flex align-items-center bg-200"
                     t-att-class="selectedLineClass(line)">
                     <div class="payment-infos d-flex align-items-center justify-content-between flex-grow-1 px-3 py-4 my-2 text-truncate cursor-pointer" t-on-click="() => this.selectLine(line)">
                         <span class="payment-name"><t t-esc="line.payment_method.name"/></span>
                         <div class="payment-amount px-3">
                            <t t-if="line and line.payment_status and ['done', 'waitingCard', 'waiting', 'reversing', 'reversed'].includes(line.payment_status)">
                                    <t t-esc="env.utils.formatCurrency(line.get_amount(), false)" />
                            </t>
                            <t t-else="">
                                    <t t-esc="formatLineAmount(line)" />
                            </t>
                        </div>
                    </div>
                    <t t-if="!line.payment_status or !['done', 'reversed', 'waitingCard', 'waitingCapture'].includes(line.payment_status)">
                        <button class="delete-button btn btn-link mx-2 px-3"
                            t-on-click="() => this.props.deleteLine(line.cid)"
                            aria-label="Delete" title="Delete">
                            <i class="fa fa-2x fa-times-circle" />
                        </button>
                    </t>

                </div>
            </t>
        </xpath>
        <xpath expr="//div[hasclass('paymentline')]//t[@t-esc='line.payment_method.name']" position="replace">
            <t t-if="line.is_stripe">
                <div class="stripe-pending">
                    <b>WAITING FOR SCAN</b>
                </div>
            </t>
            <t t-else="">
                <t t-esc="line.payment_method.name" />
            </t>
        </xpath>
    </t>

    <t t-name="bi_pos_stripe_payment.StripePopup" owl="1">
         <div class="popup popup-selection">
            <div class="modal-header">
                <t t-esc=" props.title || 'Create Expenses' "/>
            </div>

            <div class="modal-body d-flex">
                
                <form class="stripeForm" style="width: 80%;display: inline-block;">
                    <div>
                        <input class="card-extra-inputs" name="customer_name" id="customer-name" type="text" placeholder="Name" style="width: 91%;margin-left: 9%;"/>
                    </div>
                    <div>
                        <input class="card-extra-inputs" style="margin-top:1px;width: 91%;margin-left: 9%;" name="customer_phone" id="customer-number" type="number" placeholder="Mobile No." />
                    </div>
                    
                    <div class="CardInputs" style="margin-top:20px;box-sizing: border-box;height: 55px ;padding: 15px 12px !important;margin-left: 9%; border: 1px solid grey;border-radius: 7px;background-color: white;-webkit-transition: box-shadow 150ms ease;box-shadow: 0 2px 5px 0 #e6ebf1;transition: box-shadow 150ms ease;">
                        <iframe name="__privateStripeFrame8245" frameborder="0" allowtransparency="true" scrolling="no" allowpaymentrequest="true" src="https://js.stripe.com/terminal/v1/elements-inner-card-d5a870ca39c92725e90d13250e93bfa1.html#wait=false&amp;style[base][color]=%2332325d&amp;style[base][fontFamily]=%22Helvetica+Neue%22%2C+Helvetica%2C+sans-serif&amp;style[base][fontSmoothing]=antialiased&amp;style[base][fontSize]=24px&amp;style[base][::placeholder][color]=%23aab7c4&amp;style[invalid][color]=%23fa755a&amp;style[invalid][iconColor]=%23fa755a&amp;rtl=false&amp;componentName=card&amp;keyMode=test&amp;apiKey=pk_test_MSxvYoiY4rUZYGogmONOQZZi&amp;referrer=https%3A%2F%2Fodoodemo.webkul.com%3A9161%2Fpos%2Fweb%3Fconfig_id%3D1%23action%3Dpos.ui%26cids%3D1&amp;controllerId=__privateStripeController8241" style="border: none !important; margin: 0px !important; padding: 0px !important; width: 1px !important; min-width: 100% !important; overflow: hidden !important; display: block !important; user-select: none !important; will-change: transform !important; height: 28.8px;"></iframe>
                    </div>
                    <button id="stripsubmit" style="margin-left: 9%;width: 91%;">
                        <div class="refresh-button" data-cid="c60" >
                            <i style="font-size:20px;color:white" class="fa fa-refresh fa-3x fa-fw fa-spin"></i>
                        </div>
                        <span id="button-text" style="margin-left: 9%;">Pay now</span>
                    </button>
                    <p id="card-error" role="alert"></p>
                    
                </form>
            </div>

            <footer class="footer footer-flex modal-footer hide_footer">
                <div class="button cancel btn btn-lg btn-primary" t-on-mousedown.prevent="cancel">
                        <t t-esc="props.cancelText" />
                    </div>
               
            </footer>
        </div>
    </t>
</templates>