<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="stripe_config_form_view">
        <field name="name">Stripe Config Form</field>
        <field name="model">stripe.config</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active_record" type="object" class="oe_stat_button" style="margin-right:40px;" icon="fa-archive">
                            <field name="activet" widget="boolean_button"/>
                        </button>
                    </div>

                    <group>
                        <field name="name"/>
                        <field name="stripe_publishable_key" password="True" required="1"/>
                        <field name="stripe_secret_key" password="True" required="1"/>
                    </group>
                    <group>
                        <field name="pos_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="Select POS"/>
                    </group>
                    <!-- Sección para mostrar los dispositivos MPOS disponibles -->
                    <group string="Available MPOS Devices">
                        <field name="available_mpos">
                            <tree editable="bottom">
                                <field name="name"/>
                                <field name="serial_number"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record model='ir.ui.view' id='stripe_config_tree_view'>
        <field name='name'>Stripe Config Tree</field>
        <field name='model'>stripe.config</field>
        <field name='arch' type='xml'>
            <tree>
                <field name="name"/>
                <field name="stripe_publishable_key" password="True"/>
                <field name="stripe_secret_key" password="True"/>
                <field name="pos_ids"/>
            </tree>
        </field>
    </record>

    <record id="stripe_config_action" model="ir.actions.act_window">
        <field name="name">Stripe Configurations</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">stripe.config</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="menu_stripe_config" name="Stripe Configurations" parent="point_of_sale.menu_point_config_product" action="stripe_config_action" sequence="4" groups="point_of_sale.group_pos_manager,point_of_sale.group_pos_user"/>
</odoo>
