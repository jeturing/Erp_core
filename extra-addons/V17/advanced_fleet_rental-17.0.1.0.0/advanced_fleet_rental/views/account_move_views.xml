<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- This record customizes the account.move form view to include the vehicle_rental_id field after partner_id. -->
    <record id="view_move_form" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit.advanced.fleet.rental</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']"
                   position="after">
                <field name="vehicle_rental_id"/>
            </xpath>
        </field>
    </record>
</odoo>
