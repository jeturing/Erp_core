<odoo>
    <!--Form View of Cancellation Policy-->
    <record id="cancellation_policy_view_form" model="ir.ui.view">
        <field name="name">cancellation.policy.view.form</field>
        <field name="model">cancellation.policy</field>
        <field name="arch" type="xml">
            <form string="Cancellation Policy">
                <sheet>
                    <h1>
                        <field name="name"/>
                    </h1>
                    <group>
                        <field name="create_date"/>
                    </group>
                    <notebook>
                        <page string="Terms Conditions">
                            <field name="terms_conditions"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!--Tree View of Cancellation Policy-->
    <record id="cancellation_policy_view_tree" model="ir.ui.view">
        <field name="name">cancellation.policy.view.tree</field>
        <field name="model">cancellation.policy</field>
        <field name="arch" type="xml">
            <tree string="Cancellation Policies">
                <field name="name"/>
                <field name="create_date"/>
            </tree>
        </field>
    </record>
    <!--Action View of Cancellation Policy-->
    <record id="action_cancellation_policy" model="ir.actions.act_window">
        <field name="name">Cancellation Policies</field>
        <field name="res_model">cancellation.policy</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Corresponding Menu-->
    <menuitem id="menu_vehicle_rental_config" name="Configurations"
              parent="vehicle_management_root"
              sequence="100"/>
    <!--Submenu-->
    <menuitem id="menu_cancellation_policy" name="Cancellation Policy"
              parent="menu_vehicle_rental_config"
              action="action_cancellation_policy"/>
</odoo>
