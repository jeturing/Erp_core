<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="webclient_bootstrap" inherit_id="web.webclient_bootstrap">
        <xpath expr="//link[@rel='manifest']" position="replace">
            <link rel="manifest" id="pwa_manifiest" crossorigin="use-credentials" t-att-href="'/os/pwa/manifest/json/'+str(request.env.user.company_id.id)"/>
            <link rel="apple-touch-icon" id="iphone_pwa_manifiest" sizes="200x200" t-att-href="'/os/pwa/icon/'+str(request.env.user.company_id.id)+'/200'"/>
        </xpath>
        <xpath expr="//meta[@name='theme-color']" position="replace">
            <t t-set="company" t-value="request.env.user.company_id.id"/>
            <meta name="theme-color" t-att-content="request.env['os.pwa'].sudo().search([('company_id', '=', int(company))], limit=1).theme_color"/>
        </xpath>
    </template>
</odoo>
