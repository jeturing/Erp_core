<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="os_pwa_view_form" model="ir.ui.view">
        <field name="name">os.pwa.form</field>
        <field name="model">os.pwa</field>
        <field name="arch" type="xml">
            <form string="PWA Configuration">
                <group>
                    <group>
                        <field name="name"/>
                        <field name="short_name"/>
                        <field name="description"/>
                        <field name="company_id"/>
                    </group>
                    <group>
                        <field name="theme_color" widget="color"/>
                        <field name="background_color" widget="color"/>
                        <field name="display"/>
                        <!--                        <field name="display_override"/>-->
                        <field name="orientation"/>
                        <field name="icon" widget="image" class="oe_avatar"/>
                        <field name="shortcut_ids" widget="many2many_tags"/>

                    </group>
                </group>
                <notebook>
                    <page string="Screenshots">
                        <group>
                            <separator string="For Desktop"/>
                            <field name="screenshot_1" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_1'}"/>
                            <field name="screenshot_2" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_2'}"/>
                            <field name="screenshot_3" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_3'}"/>
                            <separator string="For Mobile"/>
                            <field name="screenshot_4" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_4'}"/>
                            <field name="screenshot_5" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_5'}"/>
                            <field name="screenshot_6" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_6'}"/>
                            <field name="screenshot_7" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_7'}"/>
                            <field name="screenshot_8" widget="image" options="{'size': [400, 400], 'preview_image':'screenshot_8'}"/>
                        </group>
                    </page>
                </notebook>


            </form>
        </field>
    </record>

    <record id="os_pwa_view_tree" model="ir.ui.view">
        <field name="name">os.pwa.tree</field>
        <field name="model">os.pwa</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="short_name"/>
                <field name="company_id"/>
                <field name="theme_color" widget="color"/>
                <field name="background_color" widget="color"/>
                <field name="display"/>
                <field name="orientation"/>
            </tree>
        </field>
    </record>

    <record id="os_pwa_action" model="ir.actions.act_window">
        <field name="name">PWA Backend Configuration</field>
        <field name="res_model">os.pwa</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="os_pwa_root_menu" name="PWA Backend Configuration" parent="base.menu_administration" sequence="10" action="os_pwa_action"/>
</odoo>
