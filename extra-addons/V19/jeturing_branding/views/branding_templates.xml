<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        ============================================================
        1. BRAND PROMOTION MESSAGE (footer "Powered by ...")
           Original: web.brand_promotion_message
           Contains: "Powered by <strong><a>Odoo</a></strong>"
        ============================================================
    -->
    <template id="brand_promotion_message"
              inherit_id="web.brand_promotion_message"
              name="Jeturing Brand Promotion Message">
        <xpath expr="." position="replace">
            <t name="Brand Promotion Message" t-name="web.brand_promotion_message">
                <t t-set="jeturing_logo">
                    <a target="_blank"
                       t-attf-href="https://jeturing.com?utm_source=db&amp;utm_medium=#{_utm_medium}"
                       class="badge text-bg-light">
                        <img alt="Jeturing"
                             src="https://jeturing.com/web/image/website/1/logo/Jeturing?unique=fa4444d"
                             width="120" height="30"
                             style="width: auto; height: 1.2em; vertical-align: baseline;"
                             loading="lazy"/>
                    </a>
                </t>
                <t t-set="final_message">Powered by %s%s</t>
                <t t-out="final_message % (jeturing_logo, _message and ('- ' + _message) or '')"/>
            </t>
        </xpath>
    </template>

    <!--
        ============================================================
        2. WEBSITE BRAND PROMOTION (website footer)
           Original: website.brand_promotion
           Contains: "Create a free website" → odoo.com
        ============================================================
    -->
    <template id="website_brand_promotion"
              inherit_id="website.brand_promotion"
              name="Jeturing Website Brand Promotion">
        <xpath expr="//t[@t-call='web.brand_promotion_message']" position="replace">
            <t t-call="web.brand_promotion_message">
                <t t-set="_message">
                    Create a <a target="_blank"
                        href="https://jeturing.com?utm_source=db&amp;utm_medium=website">free website</a>
                </t>
                <t t-set="_utm_medium" t-valuef="website"/>
            </t>
        </xpath>
    </template>

    <!--
        ============================================================
        3. LOGIN PAGE FOOTER
           Original: web.login_layout
           Contains: "Powered by <span>Odoo</span>" link to odoo.com
           In v19 this is directly in the template (no hide_powered_by_odoo)
        ============================================================
    -->
    <template id="login_layout_branding"
              inherit_id="web.login_layout"
              name="Jeturing Login Branding">
        <xpath expr="//a[@href='https://www.odoo.com?utm_source=db&amp;utm_medium=auth']" position="replace">
            <a href="https://jeturing.com?utm_source=db&amp;utm_medium=auth"
               target="_blank">Powered by <span>Jeturing</span></a>
        </xpath>
    </template>

    <!--
        ============================================================
        4. BROWSER TAB TITLE - "Sajet" instead of "Odoo"
           Original: web.layout → <title t-out="title or 'Odoo'"/>
        ============================================================
    -->
    <template id="layout_title_branding"
              inherit_id="web.layout"
              name="Sajet Tab Title">
        <xpath expr="//title" position="replace">
            <title t-esc="title or 'Sajet'"/>
        </xpath>
    </template>

    <!--
        ============================================================
        5. HTTP ERROR PAGE
           Original: http_routing.http_error
        ============================================================
    -->
    <template id="http_error_branding"
              inherit_id="http_routing.http_error"
              name="Jeturing Error Page">
        <xpath expr="//h1" position="after">
            <p class="container text-muted">
                If the issue persists, contact
                <a href="https://jeturing.com/support" target="_blank">Jeturing Support</a>.
            </p>
        </xpath>
    </template>

    <!--
        ============================================================
        6. 400 ERROR PAGE
           Original: http_routing.400
        ============================================================
    -->
    <template id="error_400_branding"
              inherit_id="http_routing.400"
              name="Jeturing 400 Error">
        <xpath expr="//p[contains(text(),'error message')]" position="replace">
            <p>If this problem persists, contact
               <a href="https://jeturing.com/support" target="_blank">Jeturing Support</a>.</p>
        </xpath>
    </template>

    <!--
        ============================================================
        7. 403 ERROR PAGE
           Original: http_routing.403
        ============================================================
    -->
    <template id="error_403_branding"
              inherit_id="http_routing.403"
              name="Jeturing 403 Error">
        <xpath expr="//p" position="replace">
            <p>You do not have permission to access this page.
               Contact <a href="https://jeturing.com/support" target="_blank">Jeturing Support</a>
               if you believe this is an error.</p>
        </xpath>
    </template>

    <!--
        ============================================================
        8. WEBSITE META GENERATOR (optional - removes "Odoo" from HTML source)
           Original: website.layout → <meta name="generator" content="Odoo"/>
        ============================================================
    -->
    <template id="website_meta_generator"
              inherit_id="website.layout"
              name="Jeturing Meta Generator">
        <xpath expr="//meta[@name='generator']" position="replace">
            <meta name="generator" content="Jeturing"/>
        </xpath>
    </template>

</odoo>
