<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.Widget.GraphType" owl="1">
        <div class="widget_graph_type">
            <div class="type_groups">
                <t t-foreach="Object.keys(groups)" t-as="groupName" t-key="groupName">
                    <t t-set="group" t-value="groups[groupName]"/>
                    <div class="type_group">
                        <div class="group_title">
                            <a><t t-esc="group.title" /></a>
                        </div>
                        <div class="group_options">
                            <t t-foreach="group.modes" t-as="modeName" t-key="modeName">
                                <t t-set="mode" t-value="modes[modeName]" />
                                <div t-on-click="() => onClickType.bind(this)(mode.value)">
                                    <div t-att-class="isActive(mode.value) ? 'item_type active' : 'item_type'" data-tooltip-position="top" t-att-data-tooltip="mode.title">
                                        <span>
                                            <img t-attf-src="/dynamic_odoo/static/img/svg/#{mode.icon}"/>
                                        </span>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>