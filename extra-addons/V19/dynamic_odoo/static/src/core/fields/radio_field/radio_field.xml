<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.Field.Radio" owl="1">
        <div t-att-class="getClass()">
            <div class="check_area" t-on-click="() => this.onUpdate.bind(this)(!state.value)">
                <div class="check_dot"></div>
            </div>
            <span class="field_label"><t t-esc="props.label" /></span>
            <span t-if="props.useCondition" class="radio_condition" t-on-click="showCondition">Condition</span>
        </div>
    </t>
</templates>