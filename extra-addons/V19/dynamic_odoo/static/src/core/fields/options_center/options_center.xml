<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.Field.OptionsCenter" owl="1">
        <div class="options_center ip_studio" t-on-click="showOptionsCenter">
            <t t-foreach="props.options" t-as="option" t-key="'option_center_key'+ option_index">
                <span><t t-esc="option.string" /></span>
            </t>
        </div>
    </t>
    <t t-name="dynamic_odoo.Field.OptionsCenterDialog" owl="1">
        <Dialog title="'Options Center'" size="'md'">
            <div class="options_center_dialog">
                <div class="op_head" t-if="props.canCreate">
                    <div class="w_img">
                        <img src="/dynamic_odoo/static/img/ic_todo_empty.png"/>
                    </div>
                    <div class="w_label">
                        <h3><t t-esc="props.title" /></h3>
                    </div>
                </div>
                <div class="op_con">
                    <t t-foreach="state.items" t-as="item" t-key="'options_center_item_key_'+item_index">
                        <div t-attf-class="item #{item.picked ? 'picked' : ''}" t-att-name="item.name">
                            <div class="icon">
                                <span t-if="props.usePicked" class="pick_option"
                                      t-on-click="() => item.picked = !item.picked"></span>
                            </div>
                            <div class="item_con" t-on-dblclick="() => state.itemEdit = item.name">
                                <t t-if="state.itemEdit == item.name">
                                    <input type="text" t-ref="inputUpdate" t-att-value="item.string"
                                           t-on-change.prevent="() => onUpdate.bind(this)(item.name)"/>
                                </t>
                                <t t-else="">
                                    <a><t t-esc="item.string" /></a>
                                </t>
                            </div>
                            <i t-if="props.canCreate" class="fa fa-trash rm_item"
                               t-on-click="() => onRemove.bind(this)(item.name)"/>
                        </div>
                    </t>
                </div>
                <div class="op_foot" t-if="props.canCreate">
                    <div class="item_create item">
                        <div class="icon">
                            <img src="/dynamic_odoo/static/img/svg/ic_new_todo.svg"/>
                        </div>
                        <div class="item_con">
                            <input t-ref="input" t-on-change.prevent="onAdd"
                                   t-att-placeholder="props.placeholder"/>
                        </div>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="() => {props.update(state.items); props.close()}">
                    <t t-if="props.canCreate">Create</t>
                    <t t-else="">Update</t>
                </button>
                <button class="btn" t-on-click="() => props.close()">Discard</button>
            </t>
        </Dialog>
    </t>
</templates>