<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.BatteryColorWidget" owl="1">
        <div class="battery_color_widget">
            <t t-foreach="Object.keys(colors)" t-as="key" t-key="Math.random()">
                <div class="item">
                    <div class="dropdown-toggle o-no-caret" data-bs-toggle="dropdown">
                        <div class="battery_color">
                            <span t-att-style="'background-color:' + colors[key]"></span>
                        </div>
                        <span class="battery_label"><t t-esc="groupBy" /></span>
                    </div>
                    <ul class="dropdown-menu colorpicker-menu">
                        <t t-component="ColorPalette" t-props="colorPaletteProps(key)"/>
                    </ul>
                </div>
            </t>
        </div>
    </t>
