<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.CodeEditorDialog">
        <Dialog contentClass="'dialog_code_editor'" title="'Code Editor Center'" size="'lg'">
            <div class="code_editor_center">
                <CodeEditor value="this.props.value"
                        mode="'xml'"
                        onChange.bind="handleChange"
                        class="'ace-view-editor'"
                        theme="'monokai'"
                        maxLines="1000"/>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="onUpdate.bind(this)">Update</button>
                <button class="btn" t-on-click="() => props.close()">Discard</button>
            </t>
        </Dialog>
    </t>
</templates>
