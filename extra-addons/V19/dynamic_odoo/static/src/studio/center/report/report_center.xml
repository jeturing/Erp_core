<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.Center.BreadCrumbs">
        <div class="view_tree_ctrl">
            <t t-foreach="breadcrumbs" t-as="breadcrumb" t-key="Math.random()">
                <a t-on-click="breadcrumb.onClick"><t t-esc="breadcrumb.title" /></a>
                <t t-if="breadcrumbs.length > 1 and breadcrumbs.length > (breadcrumb_index+1)">
                    <i class="fa fa-angle-right"/>
                </t>
            </t>
        </div>
    </t>

    <t t-name="dynamic_odoo.ReportCenter">
        <div class="report_center">
            <div t-if="state.type != 'choose'" class="vc_head">
                <div>
                    <t t-call="dynamic_odoo.Center.BreadCrumbs"/>
                </div>
            </div>
            <div class="center_container vc_con">
                <button t-if="state.type == 'modifier'" class="btn btn-primary print_report" t-on-click="printReport">Print</button>
                <div class="center_component">
                    <Choose t-if="state.type == 'choose'" resModel="uriState.model" model="model" onSelectRecord.bind="onSelectRecord"/>
                    <Modifier t-if="state.type == 'modifier'" resModel="uriState.model" model="model" reloadReport.bind="reload"
                              viewInfo="viewInfo"/>
                </div>
            </div>
        </div>
    </t>

    <t t-name="dynamic_odoo.Report.ReportTemplates">
        <Dialog size="'md'" title="'Choose Report Template'">
            <div class="report_templates">
                <div class="templates_container">
                    <t t-foreach="Object.keys(templates)" t-as="template" t-key="Math.random()">
                        <div t-att-class="state.template == template ? 'template_item active' : 'template_item'"
                             t-on-click="() => this.state.template = template">
                             <t t-set="template" t-value="templates[template]"/>
                            <h4><t t-esc="template.title" /></h4>
                            <p><t t-esc="template.desc" /></p>
                        </div>
                    </t>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="confirm">
                    Confirm
                </button>
            </t>
        </Dialog>
    </t>

    <t t-name="dynamic_odoo.ReportTemplates.Internal">
        <t t-name="report_name_internal">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.internal_layout">
                        <div class="page">
                            <h2>Hello</h2>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </t>

    <t t-name="dynamic_odoo.ReportTemplates.External">
        <t t-name="report_name_external">
            <t t-call="web.html_container">
                <t t-foreach="docs" t-as="doc">
                    <t t-call="web.external_layout">
                        <div class="page">
                            <h2>Hello</h2>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </t>

    <t t-name="dynamic_odoo.ReportTemplates.Blank">
        <t t-name="report_name_blank">
            <t t-call="web.html_container">
                <div class="header"></div>
                <div class="article">
                    <t t-foreach="docs" t-as="doc">
                        <div class="page">
                            <h2><t t-esc="doc.id" /></h2>
                        </div>
                    </t>
                </div>
                <div class="footer"></div>
            </t>
        </t>
    </t>

    <t t-name="dynamic_odoo.DragComponent.Table.LoadData">
        <t t-foreach="" t-as="line">
            <tr>
                <td name="td_id"><span t-field="line.id" /></td>
            </tr>
        </t>
    </t>

    <t t-name="dynamic_odoo.DragComponent.Table">
        <table class="table table-sm o_main_table table-borderless mt-4" need_data="true">
                <!-- In case we want to repeat the header, remove "display: table-row-group" -->
            <thead style="display: table-row-group">
                <tr>
                    <th name="th_description" class="text-start">Studio Website</th>
                </tr>
            </thead>
            <tbody class="data_tbody">
                <tr>
                    <td><a href="https://odoo-studio.com">https://odoo-studio.com</a></td>
                </tr>
            </tbody>
        </table>
    </t>

    <t t-name="dynamic_odoo.DragComponent.CheckBoxList.option">
        <div>
            <span class="rp_checkbox"></span>
            <span>Option 1</span>
        </div>
    </t>

    <t t-name="dynamic_odoo.DragComponent.CheckBoxList">
        <div class="re_checkbox_list" component="checkbox_list">
            <div>
                <span class="rp_checkbox"></span>
                <span>Option 1</span>
            </div>
            <div>
                <span class="rp_checkbox"></span>
                <span>Option 1</span>
            </div>
        </div>
    </t>

</templates>