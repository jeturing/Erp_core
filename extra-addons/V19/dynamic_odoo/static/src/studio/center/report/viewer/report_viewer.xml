<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.ReportViewer" owl="1">
        <div class="report_viewer">
            <div class="report_action">
                <div class="undo_redo">
                    <button class="btn undo_report" t-att-disable="!props.can_undo"
                            t-on-click="() => onHistory.bind(this)('undo')"><i class="fa fa-undo" />
                        UNDO</button>
                    <button class="btn redo_report" t-att-disable="!props.can_redo"
                            t-on-click="() => onHistory.bind(this)('redo')"><i class="fa fa-repeat" />
                        REDO</button>
                </div>
            </div>
            <div class="report_preview">
                <link type="text/css" rel="stylesheet" href="/web/assets/debug/web.report_assets_common.css"/>
                <div class="report_content" t-ref="preview" t-on-dblclick="onShowArea" t-att-show_area="state.show_area"></div>
            </div>
        </div>
    </t>

    <t t-name="dynamic_odoo.ReportChooseTemplate" owl="1">
        <div class="report_templates">
            <div>

            </div>
        </div>
    </t>

</templates>