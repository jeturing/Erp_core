<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.Field.Approval" owl="1">
        <div class="approval">
            <div class="approval_con">
                <t t-set="rules" t-value="state.rules.filter((rule) => rule.type !== 'delete')" />
                <t t-foreach="rules" t-as="rule" t-key="'rule_'+ Math.random()">
                    <t t-set="fields" t-value="makeFields(rule)"/>
                    <div class="rule">
                        <div class="rule_head">
                            <h4 t-on-click="() => (rule.active = !rule.active)">
                                <i class="fa fa-fw fa-caret-right"/>
                                <t t-esc="'Rule '+ (rule_index + 1)"/>
                            </h4>
                            <span>
                                <i class="fa fa-fw fa-filter" t-on-click="() => onShowFilter.bind(this)(rule)"></i>
                                <i class="fa fa-fw fa-trash" t-on-click="() => onDelete.bind(this)(rule)"></i>
                            </span>
                        </div>
                        <div t-if="rule.active" class="rule_content">
                            <t t-foreach="Object.keys(fields)" t-as="fieldName"
                               t-key="'field_' + rule_index + '_' + fieldName_index">
                                <Field t-props="fields[fieldName]"/>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
            <div class="new_approval">
                <a t-on-click="newApprovalRule">
                    <i class="fa fa-fw   fa-plus me-2"/>Add an approval rule
                </a>
            </div>
        </div>
    </t>
</templates>