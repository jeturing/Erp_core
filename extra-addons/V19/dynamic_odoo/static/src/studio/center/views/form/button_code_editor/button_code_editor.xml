<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.ButtonCodeEditor">
        <div class="code_editor_center">
            <CodeEditor value="this.buttonData.python_code"
                        mode="'python'"
                        onChange.bind="handleChange"
                        class="'ace-view-editor'"
                        theme="'monokai'"
                        maxLines="1000"/>
        </div>
    </t>
</templates>
