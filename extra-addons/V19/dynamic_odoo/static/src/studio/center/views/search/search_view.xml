<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.SearchView">
        <div class="studio_search_view">
            <t t-set="groupData" t-value="searchData"/>
            <div class="wrap_search">
                <t t-foreach="groupData" t-as="group" t-key="Math.random()">
                    <div class="search_type">
                        <div class="type_header">
                            <i t-att-class="group.icon"/>
                            <span><t t-esc="group.string" /></span>
                        </div>
                        <div class="items" t-att-node-id="props.viewInfo.archJson.nodeId" t-att-type="group.type">
                            <t t-foreach="group.data" t-as="item" t-key="Math.random()">
                                <div t-att-node-id="item.nodeId" t-att-class="item.type == 'separator' ? 'separator dropdown-divider' : 'item'">
                                    <span t-if="item.type != 'separator'"><t t-esc="item.description" /></span>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
