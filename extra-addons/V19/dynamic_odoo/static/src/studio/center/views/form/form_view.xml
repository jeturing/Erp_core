    <t t-name="dynamic_odoo.One2manyEdit" owl="1">
        <div class="wrap_one2many">
            <t t-slot="default"/>
            <t t-set="viewEdit" t-value="Object.keys(props.fieldInfo.views || {})"/>
            <div class="edit_one2many" t-if="viewEdit.length">
                <div class="wrap_btn">
                    <button t-if="props.fieldInfo.views.list" class="btn btn-primary" data-tooltip-position="top"
                            data-tooltip="Edit List View" t-on-click="() => this.onEditView('list')">Edit List</button>
                    <button t-if="props.fieldInfo.views.list" class="btn btn-primary" data-tooltip-position="top"
                            data-tooltip="Edit Form View" t-on-click="() => this.onEditView('form')">Edit Form</button>
                </div>
            </div>
        </div>
    </t>

    <t t-name="dynamic_odoo.WrapComponent" owl="1">
        <t t-if="isXMany">
            <One2ManyModifier t-props="props">
                <t t-ref="component" t-slot="compile_component"/>
            </One2ManyModifier>
        </t>
        <t t-else=""><t t-ref="component" t-slot="compile_component" /></t>
    </t>

    <t t-name="dynamic_odoo.Form.InnerGroup" t-inherit="web.Form.InnerGroup"
       t-inherit-mode="primary" owl="1">
         <xpath expr="//div[@t-foreach]" position="attributes">
             <attribute name="t-attf-node-id">{{getNodeId(row)}}</attribute>
        </xpath>
    </t>

    <t t-name="dynamic_odoo.Form.Notebook" t-inherit="web.Notebook"
       t-inherit-mode="primary" owl="1">
        <xpath expr="//li[@t-foreach='navItems']" position="attributes">
            <attribute name="t-att-node-id">navItem[1]['node-id']</attribute>
        </xpath>
        <xpath expr="//li[@t-foreach='navItems']" position="after">
            <li class="add_page" t-on-click.prevent="onAddPage"><i class="fa fa-plus" /></li>
        </xpath>
        <xpath expr="//div[@t-ref]" position="attributes">
             <attribute name="t-att-node-id">props.slots[state.currentPage]['node-id']</attribute>
        </xpath>
    </t>

    <t t-name="dynamic_odoo.Form.ButtonBox" t-inherit="web.Form.ButtonBox"
       t-inherit-mode="primary" owl="1">
        <xpath expr="//t[@t-foreach='visibleButtons']" position="before">
            <button class="btn oe_stat_button add_button_box" t-on-click="onAddButton">
                <i class="fa fa-fw o_button_icon fa-plus icon"/>
            </button>
        </xpath>
    </t>

    <t t-name="dynamic_odoo.form.TabComponents" owl="1">
        <div class="tab_components">
            <div class="tags_component">
                <h4>Tags</h4>
                <div>
                    <t t-foreach="Object.keys(constructor.components)" t-as="comName" t-key="Math.random()">
                        <t t-if="comName != 'OhField'" t-component="constructor.components[comName]"/>
                    </t>
                </div>
            </div>
            <div class="fields_component">
                <h4>Fields</h4>
                <div>
                    <t t-set="fSupport" t-value="fieldsSupported"/>
                    <t t-foreach="Object.keys(fSupport)" t-as="fieldType" t-key="Math.random()">
                        <t t-set="field" t-value="fSupport[fieldType]"/>
                        <t t-component="constructor.components.OhField"
                           t-props="{name: field.type || fieldType, ...field}"/>
                    </t>
                </div>
            </div>
        </div>
    </t>
    <t t-name="dynamic_odoo.Form.Chatter" owl="1">
        <div class="oe_chatter">
            <field name="message_follower_ids"/>
            <field name="activity_ids"/>
            <field name="message_ids"/>
        </div>
    </t>
    <t t-name="dynamic_odoo.Form.View.default" owl="1">
        <form string="Studio Form">
            <header></header>
            <sheet>
                <div class="oe_button_box" name="button_box">
                </div>
                <group>
                    <group>
                        <field name="create_uid"/>
                    </group>
                    <group>
                        <field name="id"/>
                    </group>
                </group>
                <notebook>
                    <page string="New Page" name="new_page">
                        <group>
                            <group></group>
                            <group></group>
                        </group>
                    </page>
                </notebook>
            </sheet>
            <t t-call="dynamic_odoo.Form.Chatter"/>
        </form>
    </t>
    <t t-name="dynamic_odoo.DragCom.ReplaceTemplate.Group" owl="1">
        <div class="o_group row align-items-start">
            <div class="o_inner_group grid col-lg-6"> </div>
            <div class="o_inner_group grid col-lg-6"> </div>
        </div>
    </t>
    <t t-name="dynamic_odoo.DragCom.NodeTemplate.Group" owl="1">
        <group>
            <group>
            </group>
            <group>
            </group>
        </group>
    </t>
    <t t-name="dynamic_odoo.DragComponent.Notebook" owl="1">
        <notebook>
           <page string="New Page">
               <group>
                    <group></group>
                   <group></group>
               </group>
           </page>
        </notebook>
    </t>
    <t t-name="dynamic_odoo.DragCom.ReplaceTemplate.Notebook" owl="1">
        <div class="o_notebook d-flex w-100 horizontal flex-column ui-sortable-handle">
            <div class="o_notebook_headers">
                <ul class="nav nav-tabs flex-row flex-nowrap">
                    <li class="nav-item flex-nowrap cursor-pointer">
                        <a class="nav-link active" name="new_page">New Page</a>
                    </li>
                </ul>
            </div>
            <div class="o_notebook_content tab-content">
                <div class="tab-pane active">
                    <div class="o_group row">
                        <div class="o_inner_group grid col-lg-6"> </div>
                        <div class="o_inner_group grid col-lg-6"> </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
    <t t-name="dynamic_odoo.DragComponent.Text" owl="1">
        <span>This is a text !!!</span>
    </t>
    <t t-name="dynamic_odoo.DragComponent.Button" owl="1">
        <button class="btn btn-secondary" type="object">New Button</button>
    </t>
</templates>