<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="dynamic_odoo.MoreCenter" owl="1">
        <div class="more_center">
            <div class="more_head vc_head">
                <div class="view_tree_ctrl">
                    <t t-foreach="breadcrumbs" t-as="breadcrumb" t-key="Math.random()">
                        <a t-on-click="breadcrumb.onClick"><t t-esc="breadcrumb.title" /></a>
                        <t t-if="breadcrumbs.length > 1 and breadcrumbs.length > (breadcrumb_index+1)">
                            <i class="fa fa-angle-right"/>
                        </t>
                    </t>
                </div>
            </div>
            <div class="more_container vc_con">
                <div class="container" t-if="!state.center">
                    <div class="row">
                        <t t-foreach="Object.keys(centerSupport)" t-as="centerName" t-key="Math.random()">
                            <t t-set="center" t-value="centerSupport[centerName]"/>
                            <div class="col-lg-3">
                                <div class="card" t-on-click="() => this.state.center = centerName">
                                    <div class="thumbnail">
                                        <i t-att-class="center.icon" t-att-style="'color:'+(center.color || 'white')"/>
                                    </div>
                                    <div class="card-info">
                                        <a>
                                            <h3><t t-esc="center.title" /></h3>
                                            <p><t t-esc="center.description" /></p>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
                <div t-if="state.center" class="more_component">
                    <t t-component="centerSupport[state.center].component" t-props="props"/>
                </div>
            </div>
        </div>
    </t>
    <t t-name="dynamic_odoo.Login.Viewer">
        <div class="login_desginer">
            <link rel="preload"
                  href="/web/static/src/libs/fontawesome/fonts/fontawesome-webfont.woff2?v=4.7.0"
                  as="font" crossorigin=""/>
            <link type="text/css" rel="stylesheet" href="/web/assets/debug/web.assets_frontend.css"/>
            <div class="login_content" t-ref="preview">
            </div>
        </div>
    </t>
</templates>