<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.views.ViewButton" t-inherit-mode="extension">
         <xpath expr="//t[@t-slot='contents']" position="after">
             <Approval btn_key="props.btn_key" approvals="props.approvals"/>
        </xpath>
    </t>
    <t t-name="studio.ApprovalDetails">
        <div class="approval-rules">
            <div class="head">
                <h6>Approval</h6>
            </div>
            <t t-foreach="props.approvals || []" t-as="approval" t-key="'approval_'+Math.random()">
                <div class="approval-rule">
                    <div class="approval_avatar">
                        <i t-if="!approval.user_id" class="fa fa-user-circle"/>
                        <img t-if="approval.user_id"
                             t-attf-src="/web/image/res.users/#{approval.user_id}/avatar_128"
                             t-attf-class="rounded-circle border #{approval.state == 'accept' ? 'border-info' : 'border-danger'}"
                             title="Mitchell Admin"/>
                    </div>
                    <div class="approval_details">
                        <t t-if="['accept', 'decline'].includes(approval.state)">
                            <h7><t t-esc="approval.group_name" /></h7>
                            <span><t t-esc="approval.state == 'accept' ? 'Accepted on ' : 'Rejected on '" />
                                <t t-esc="formatDateTime(approval.date_accepted)"/></span>
                        </t>
                        <t t-else="">
                            <span style="font-weight: 400"><t t-esc="approval.description || 'Awaiting approval'" /></span>
                            <span><t t-esc="approval.group_name" /></span>
                        </t>
                    </div>
                    <div class="approval_button">
                        <t t-if="approval.state == 'wait'">
                            <button class="btn btn-primary btn-sm btn-block"
                                    t-on-click="() => onAction.bind(this)('accept', approval)"><i class="fa fa-fw fa-check" /></button>
                            <button class="btn btn-danger btn-sm btn-block"
                                    t-on-click="() => onAction.bind(this)('decline', approval)"><i class="fa fa-fw fa-times" /></button>
                        </t>
                        <t t-if="['accept', 'decline'].includes(approval.state)">
                            <button class="btn btn-secondary btn-sm approval-cancel btn-block"
                                    t-on-click="() => onAction.bind(this)('wait', approval)"><i class="fa fa-fw fa-undo" /></button>
                        </t>
                    </div>
                </div>
            </t>
        </div>
    </t>
    <t t-name="studio.form_view.approval">
        <span t-if="approvals">
            <span class="wrap_approval" t-on-click.prevent.stop="showDetails">
                <t t-foreach="approvals" t-as="approval" t-key="'approval_'+Math.random()">
                    <span class="sp_approval">
                        <i t-if="!approval.user_id" class="fa fa-user-circle"/>
                        <img t-if="approval.user_id"
                             t-attf-src="/web/image/res.users/#{approval.user_id}/avatar_128"
                             t-attf-class="rounded-circle border #{approval.state == 'accept' ? 'border-info' : 'border-danger'}"
                             title="Mitchell Admin"/>
                    </span>
                </t>
            </span>
        </span>
    </t>
</templates>