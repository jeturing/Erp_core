<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.ListRenderer" t-inherit-mode="extension">
        <xpath expr="//tbody/t" position="before">
            <tr class="tr_search_in_tree" t-if="props.archInfo.searchInTree">
                <td t-if="hasSelectors" class="th_search"></td>
                <t t-foreach="state.columns" t-as="column" t-key="'search_in_tree_'+column.name">
                    <td class="th_search">
                        <SearchInTree field="props.list.fields[column.name]"/>
                    </td>
                </t>
                <td t-if="displayOptionalFields or activeActions.onDelete" class="th_search"></td>
            </tr>
        </xpath>
    </t>
</templates>