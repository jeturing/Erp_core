<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="dynamic_odoo.DashboardCard.more">
        <Dropdown togglerClass="'card_more'" showCaret="false">
            <t t-set-slot="toggler"><i class="card_icon fa fa-ellipsis-h"/></t>
            <div class="select_card_more">
                <t t-foreach="cardView" t-as="opName" t-key="opName">
                    <t t-set="option" t-value="cardAction[opName]"/>
                    <div>
                        <a t-on-click="option.fn"><i t-att-class="'fa '+option.icon" />
                            <t t-esc="option.label"/></a>
                    </div>
                </t>
            </div>
        </Dropdown>
    </t>
    <t t-name="dynamic_odoo.DashboardCard">
        <div class="dbCard" t-att-card_type="props.viewInfo.viewType">
            <div class="card_header">
                <div t-if="props.showTitle" class="card_title">
                    <h3><t t-esc="props.viewInfo.title" /></h3>
                </div>
                <div class="card_options">
                    <Dropdown t-if="props.canExport" showCaret="false">
                        <t t-set-slot="toggler"><i class="fa fa-download"/></t>
                        <div class="card_select_options">
                            <t t-foreach="Object.keys(exportOptions)" t-as="opName" t-key="opName">
                                <t t-set="option" t-value="exportOptions[opName]"/>
                                <div>
                                    <a t-on-click="option.fn"><i t-att-class="'fa '+option.icon" /><t t-esc="option.label"/></a>
                                </div>
                            </t>
                        </div>
                    </Dropdown>
                    <a class="card_full" t-on-click="onFullScreen">
                        <i class="card_icon fa fa-arrows-alt"/>
                    </a>
                </div>
            </div>
            <div class="card_content">
                <DashboardComponent viewInfo="props.viewInfo"/>
            </div>
        </div>
    </t>
    <t t-name="dynamic_odoo.DashboardRenderer">
        <div class="o_dashboard table-responsive">
            <div class="grid-stack">
            </div>
        </div>
    </t>
</templates>
