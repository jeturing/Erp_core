<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="odoo_menu_management.OMMItem" owl="1">
        <div t-if="state.oMenu" class="omm_screen_item">
            <t t-set="oMenu" t-value="state.oMenu"/>
            <div class="omm_title omm_title_header omm_column" t-attf-style="padding-left: {{oMenu.level}}px;" t-on-mouseover="(ev) => this._onShowCompleteName(ev,oMenu.id)" t-on-click="() => this._onShowDetails(oMenu.id)">
                <div t-if="oMenu.web_icon_data" class="omm_app_img" t-attf-style="background-image:url({{'/web/image/ir.ui.menu/'+ oMenu.id + '/web_icon_data/'}});"/>
                <div t-out="oMenu.name"/>
            </div>
            <div class="omm_global_hide omm_setting_stripe text-center omm_column" t-att-title="props.helps[0]" t-on-click="(ev) => this._onToggleHideGlobal(ev,oMenu.id)">
                <i t-attf-class="fa {{oMenu.hide_global and 'fa-check-square-o' or 'fa fa-square-o'}} omm_icon"/>
            </div>
            <div class="omm_setting omm_column" t-att-title="props.helps[1]" t-on-click="() => this._onOpenM2MChange(oMenu.id, 'hide_user_global_ids')">
                <t t-if="oMenu.hide_user_global_ids">
                    <t t-foreach="oMenu.hide_user_global_ids" t-as="hideUser" t-key="hideUser_index">
                        <div class="w-100">
                            <span t-out="hideUser"/>
                        </div>
                    </t>
                </t>
            </div>
            <div class="omm_setting omm_setting_stripe omm_column" t-att-title="props.helps[2]" t-on-click="() => this._onOpenM2MChange(oMenu.id, 'hide_user_ids')">
                <t t-if="oMenu.hide_user_ids">
                    <t t-foreach="oMenu.hide_user_ids" t-as="showUser" t-key="showUser_index">
                        <div class="w-100">
                            <span t-out="showUser"/>
                        </div>
                    </t>
                </t>
            </div>
            <div class="omm_setting omm_column" t-att-title="props.helps[3]" t-on-click="() => this._onOpenM2MChange(oMenu.id, 'show_user_ids')">
                <t t-if="oMenu.show_user_ids">
                    <t t-foreach="oMenu.show_user_ids" t-as="showUser" t-key="showUser_index">
                        <div class="w-100">
                            <span t-out="showUser"/>
                        </div>
                    </t>
                </t>
            </div>
            <div class="omm_setting omm_setting_stripe omm_column" t-att-title="props.helps[4]" t-on-click="() => this._onOpenM2MChange(oMenu.id, 'hide_for_company_ids')">
                <t t-if="oMenu.hide_for_company_ids">
                    <t t-foreach="oMenu.hide_for_company_ids" t-as="hideCompany" t-key="hideCompany_index">
                        <div class="w-100" t-out="hideCompany">
                            <span t-out="hideCompany"/>
                        </div>
                    </t>
                </t>
            </div>
            <div class="omm_setting omm_column" t-att-title="props.helps[5]" t-on-click="() => this._onOpenM2MChange(oMenu.id, 'show_for_company_ids')">
                <t t-if="oMenu.show_for_company_ids">
                    <t t-foreach="oMenu.show_for_company_ids" t-as="showCompany" t-key="showCompany_index">
                        <div class="w-100" t-out="showCompany">
                            <span t-out="showCompany"/>
                        </div>
                    </t>
                </t>
            </div>
            <div class="omm_setting omm_setting_stripe omm_column" t-att-title="props.helps[6]" t-on-click="() => this._onOpenM2MChange(oMenu.id, 'show_for_group_ids')">
                <t t-if="oMenu.show_for_group_ids">
                    <t t-foreach="oMenu.show_for_group_ids" t-as="showGroup" t-key="showGroup_index">
                        <div class="w-100">
                            <span t-out="showGroup"/>
                        </div>
                    </t>
                </t>
            </div>
        </div>
    </t>

</templates>
