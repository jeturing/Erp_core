<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Adapt standard ir.ui.menu -->
        <record id="ir_ui_menu_view_form" model="ir.ui.view">
            <field name="name">ir_ui_menu.view.form.omm</field>
            <field name="model">ir.ui.menu</field>
            <field name="inherit_id" ref="base.edit_menu_access"/>
            <field name="arch" type="xml">
                <notebook position="inside">
                    <page string="Advanced Management">
                        <group>
                            <group string="Global">
                                <field name="hide_global"/>
                            </group>
                            <group string="Groups">
                                <field name="show_for_group_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                            </group>
                            <group string="Users">
                                <field name="hide_user_global_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                <field name="hide_user_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                <field name="show_user_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                            </group>
                            <group string="Companies">
                                <field name="hide_for_company_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                <field name="show_for_company_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                            </group>
                        </group>
                    </page>
                </notebook>
            </field>
        </record>
        <!-- Introduce own ir.ui.menu form view -->
        <record id="ir_ui_menu_view_form_special" model="ir.ui.view">
            <field name="name">ir_ui_menu.view.form.omm.special</field>
            <field name="model">ir.ui.menu</field>
            <field name="priority">10000</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="parent_id"/>
                                <field name="sequence"/>
                            </group>
                            <group>
                                <field name="complete_name"/>
                                <field name="action"/>
                                <field name="web_icon"/>
                                <field name="web_icon_data"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Advanced Management">
                                <group>
                                    <group string="Global">
                                        <field name="hide_global"/>
                                    </group>
                                    <group string="Groups">
                                        <field name="show_for_group_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                    </group>
                                    <group string="Users">
                                        <field name="hide_user_global_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                        <field name="hide_user_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                        <field name="show_user_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                    </group>
                                    <group string="Companies">
                                        <field name="hide_for_company_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                        <field name="show_for_company_ids" widget="many2many_tags" options="{'no_create_edit': 1, 'no_quick_create': 1}"/>
                                    </group>
                                </group>
                            </page>
                            <page string="Access Rights" name="access_rights">
                                <field name="groups_id"/>
                            </page>
                            <page string="Submenus" name="submenus">
                                <field name="child_id" context="{'default_parent_id': id}">
                                    <tree string="Menu">
                                        <field name="sequence"/>
                                        <field icon="icon" name="name" string="Menu"/>
                                    </tree>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!-- Short view for js triggering of certain fields -->
        <record id="ir_ui_menu_view_form_omm_m2m" model="ir.ui.view">
            <field name="name">ir_ui_menu.view.form.omm.m2m</field>
            <field name="model">ir.ui.menu</field>
            <field name="priority">10000</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="hide_user_global_ids"
                               widget="many2many_tags"
                               options="{'no_create_edit': 1, 'no_quick_create': 1}"
                               invisible="context.get('omm_regime') != 'hide_user_global_ids'"
                               class="w-100 w-100-field"
                               placeholder="Hide for users"
                        />
                        <field name="hide_user_ids"
                               widget="many2many_tags"
                               options="{'no_create_edit': 1, 'no_quick_create': 1}"
                               invisible="context.get('omm_regime') != 'hide_user_ids'"
                               class="w-100 w-100-field"
                               placeholder="Hide for users"
                        />
                        <field name="show_user_ids"
                               widget="many2many_tags"
                               options="{'no_create_edit': 1, 'no_quick_create': 1}"
                               invisible="context.get('omm_regime') != 'show_user_ids'"
                               class="w-100 w-100-field"
                               placeholder="Show only for users"
                        />
                        <field name="hide_for_company_ids"
                               widget="many2many_tags"
                               options="{'no_create_edit': 1, 'no_quick_create': 1}"
                               invisible="context.get('omm_regime') != 'hide_for_company_ids'"
                               class="w-100 w-100-field"
                               placeholder="Hide for companies"
                        />
                        <field name="show_for_company_ids"
                               widget="many2many_tags"
                               options="{'no_create_edit': 1, 'no_quick_create': 1}"
                               invisible="context.get('omm_regime') != 'show_for_company_ids'"
                               class="w-100 w-100-field"
                               placeholder="Show only for companys"
                        />
                        <field name="show_for_group_ids"
                               widget="many2many_tags"
                               options="{'no_create_edit': 1, 'no_quick_create': 1}"
                               invisible="context.get('omm_regime') != 'show_for_group_ids'"
                               class="w-100 w-100-field"
                               placeholder="Show only for groups"
                        />
                    </sheet>
                </form>
            </field>
        </record>
        <!-- The speciaal action (@see components) -->
        <record id="ir_ui_menu_action_advanced" model="ir.actions.client">
            <field name="name">Menu Management</field>
            <field name="tag">odoo.menu.management</field>
            <field name="res_model">ir.ui.menu</field>
        </record>
        <menuitem name="Menu Management"
                  id="menu_omm"
                  sequence="45"
                  parent="base.menu_administration"
                  action="odoo_menu_management.ir_ui_menu_action_advanced"
        />

    </data>
</odoo>