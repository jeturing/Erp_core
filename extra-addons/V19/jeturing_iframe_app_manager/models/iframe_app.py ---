from odoo import models, fields

class IframeApp(models.Model):
    _name = "iframe.app"
    _description = "Aplicación externa embebida via IFrame"

    name = fields.Char("Nombre", required=True)
    url = fields.Char("URL del iframe", required=True)
    auth_type = fields.Selection([
        ('token', 'API Token'),
        ('basic', 'Usuario y Clave')
    ], string="Tipo de Autenticación", required=True)
    token = fields.Char("Token API")
    username = fields.Char("Usuario")
    password = fields.Char("Clave")
    active = fields.Boolean(default=True)