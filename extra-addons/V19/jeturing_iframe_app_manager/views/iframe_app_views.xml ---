<odoo>
    <record id="view_iframe_app_form" model="ir.ui.view">
        <field name="name">iframe.app.form</field>
        <field name="model">iframe.app</field>
        <field name="arch" type="xml">
            <form string="Aplicación Externa">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="url"/>
                        <field name="auth_type"/>
                        <field name="token" attrs="{'invisible': [('auth_type', '!=', 'token')]}"/>
                        <field name="username" attrs="{'invisible': [('auth_type', '!=', 'basic')]}"/>
                        <field name="password" attrs="{'invisible': [('auth_type', '!=', 'basic')]}"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_iframe_app_tree" model="ir.ui.view">
        <field name="name">iframe.app.tree</field>
        <field name="model">iframe.app</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="url"/>
                <field name="auth_type"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="action_iframe_app" model="ir.actions.act_window">
        <field name="name">Aplicaciones Externas</field>
        <field name="res_model">iframe.app</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>