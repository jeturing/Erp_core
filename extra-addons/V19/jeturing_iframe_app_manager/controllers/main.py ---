from odoo import http
from odoo.http import request
import requests

class IframeAppController(http.Controller):

    @http.route('/iframe_app/<int:app_id>', type='http', auth='user', website=True)
    def iframe_app_render(self, app_id, **kwargs):
        app = request.env['iframe.app'].sudo().browse(app_id)
        headers = {}

        if app.auth_type == 'token' and app.token:
            headers['Authorization'] = f"Bearer {app.token}"
        elif app.auth_type == 'basic' and app.username and app.password:
            from base64 import b64encode
            creds = b64encode(f"{app.username}:{app.password}".encode()).decode()
            headers['Authorization'] = f"Basic {creds}"

        resp = requests.get(app.url, headers=headers)
        content = resp.text if resp.ok else f"<h2>Error cargando app: {resp.status_code}</h2>"

        return request.render("jeturing_iframe_app_manager.iframe_proxy", {
            'iframe_html': content,
            'app_name': app.name,
        })