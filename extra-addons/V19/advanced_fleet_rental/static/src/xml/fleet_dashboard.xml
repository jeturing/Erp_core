<templates xml:space="preserve">
<!--    Fleet Dashboard-->
    <t t-name="FleetDashboard" owl="1">
        <div class="vh-100 overflow-auto bg-muted">
            <div class="row components">
                <!-- Heading -->
                <div class="heading text-center">
                    <div class="h1" style="color:black;">FLEET DASHBOARD</div>
                </div>
                <hr style="color:white;"/>

                <!-- Total Vehicles -->
                <div class="col-lg-4">
                    <div class="border m-2 text-center tile"
                         t-on-click="onClickVehicles"
                         style="background-image: radial-gradient( circle farthest-corner at 10% 20%,  rgba(176,229,208,1) 42%, rgba(92,202,238,0.41) 93.6% );">
                        <div class="h1 fw-bold text-dark"><t t-esc="state.data.total_vehicles"/></div>
                        <div class="h3">Total Vehicles</div>
                    </div>
                </div>

                <!-- Available Vehicles -->
                <div class="col-lg-4">
                    <div class="border m-2 text-center tile"
                         t-on-click="onClickAvailableVehicles"
                         style="background-image: linear-gradient( 108.1deg,  rgba(167,220,225,1) 11.2%, rgba(217,239,242,1) 88.9% );">
                        <div class="h1 fw-bold text-dark"><t t-esc="state.data.operational"/></div>
                        <div class="h3">Available Vehicles</div>
                    </div>
                </div>

                <!-- Under Maintenance -->
                <div class="col-lg-4">
                    <div class="border m-2 text-center tile"
                         t-on-click="onClickUnderMaintenanceVehicles"
                         style="background-image: radial-gradient( circle 674px at 18.3% 77%,  rgba(139,186,244,1) 3.4%, rgba(15,51,92,1) 56.6% );">
                        <div class="h1 fw-bold text-dark"><t t-esc="state.data.under_maintenance"/></div>
                        <div class="h3">Under Maintenance</div>
                    </div>
                </div>
                <!-- All Customers -->
                <div class="col-lg-4">
                    <div class="border m-2 text-center tile"
                         t-on-click="onClickAllCustomers"
                         style="background-image: linear-gradient( 109.6deg,  rgba(177,173,219,1) 11.2%, rgba(245,226,226,1) 91.1% );">
                        <div class="h1 fw-bold text-dark"><t t-esc="state.data.all_customers"/></div>
                        <div class="h3">All Customers</div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="border m-2 text-center tile"
                         t-on-click="onClickInvoices"
                         style="background-image: radial-gradient( circle 867px at -5.8% 1.8%,  rgba(255,255,255,1) 0%, rgba(7,0,216,1) 100.3% );">
                        <div class="h1 fw-bold text-dark"><t t-esc="state.data.all_invoices"/></div>
                        <div class="h3">All Invoices</div>
                    </div>
                </div>
                <div class="col-lg-4">
                    <div class="border m-2 text-center tile"
                         t-on-click="onPendingInvoices"
                         style="background-image: linear-gradient( 109.6deg,  rgba(177,173,219,1) 11.2%, rgba(245,226,226,1) 91.1% );">
                        <div class="h1 fw-bold text-dark"><t t-esc="state.data.pending_invoices"/></div>
                        <div class="h3">Pending Invoices</div>
                    </div>
                </div>
            </div>
            <div style="padding-left:3%;padding-right:3%;">
                <h2 class="contracts-header contracts-header-gradient">Contracts Details</h2>
                <div class="row">
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card"
                             style="background-image: linear-gradient( 108.1deg,  rgba(167,220,225,1) 11.2%, rgba(217,239,242,1) 88.9% );width:100%;height:200px; display:flex;align-items:center; justify-content: center;"
                             t-on-click="onAllContract">
                            <div style="text-align: center;">
                                <img src="advanced_fleet_rental/static/src/images/car-insurance.svg"
                                     style="height: 48px; width: 48px;"/>
                                <h5 class="card-title"
                                    style="padding:0.7rem 0; font-size:1.3rem;margin-bottom:0px;">Contracts</h5>
                                <p class="card-text h3"
                                   style="text-align: center;"><t t-esc="state.data.total_contracts"/></p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card"
                             style="background-image: linear-gradient(108.1deg, rgba(255, 236, 170, 1) 11.2%, rgba(255, 245, 217, 1) 88.9%);width:100%;height:200px; display:flex;align-items:center; justify-content: center;"
                             t-on-click="onInProgressContract">
                            <div style="text-align: center;">
                                <img src="advanced_fleet_rental/static/src/images/car.svg"
                                     style="height: 48px; width: 48px;"/>
                                <h5 class="card-title"
                                    style="padding:0.7rem 0; font-size:1.3rem;margin-bottom:0px;">In Progress</h5>
                                <p class="card-text h3"
                                   style="text-align: center;"><t t-esc="state.data.total_contract_working"/></p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card"
                             style="background-image: linear-gradient(108.1deg, rgba(183, 237, 211, 1) 11.2%, rgba(222, 255, 241, 1) 88.9%);width:100%;height:200px; display:flex;align-items:center; justify-content: center;"
                             t-on-click="onReturnContract">
                            <div style="text-align: center;">
                                <img src="advanced_fleet_rental/static/src/images/return.svg"
                                     style="height: 48px; width: 48px;"/>
                                <h5 class="card-title"
                                    style="padding:0.7rem 0; font-size:1.3rem;margin-bottom:0px;">Return</h5>
                                <p class="card-text h3"
                                   style="text-align: center;"><t t-esc="state.data.total_contract_return"/></p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 col-sm-6 mb-3">
                        <div class="card"
                             style="background-image: linear-gradient(108.1deg, rgba(255, 204, 204, 1) 11.2%, rgba(255, 230, 230, 1) 88.9%);width:100%;height:200px; display:flex;align-items:center; justify-content: center;"
                             t-on-click="onCancelContract">
                            <div style="text-align: center;">
                                <img src="advanced_fleet_rental/static/src/images/transport.svg"
                                     style="height: 48px; width: 48px;"/>
                                <h5 class="card-title"
                                    style="padding:0.7rem 0; font-size:1.3rem;margin-bottom:0px;">Cancelled</h5>
                                <p class="card-text h3"
                                   style="text-align: center;"><t t-esc="state.data.total_contract_cancel"/></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="row chart">
                <div class="col m-0 p-0">
                    <div class="shadow-sm border m-2 p-4 bg-white"
                         style="border-radius: 15px">
                        <div class="d-flex align-items-center justify-content-between">
                            <h3 class="text-primary fw-bold">Monthly Contract Invoices</h3>
                        </div>
                        <canvas t-ref="MonthlyInvoice" height="50px"
                                width="150px"/>
                    </div>
                </div>
            </div>
            <div class="row chart">
                <div class="col m-0 p-0">
                    <div class="shadow-sm border m-2 p-4 bg-white"
                         style="border-radius: 15px; border-radius: 15px;text-align: unset;display: flex;flex-direction: column;align-content: center;flex-wrap: wrap;position: relative">
                            <h3 style="width: 100%;position: absolute;left: 31px;" class="text-primary fw-bold">Vehicle Status</h3>

                        <div style="height: 500px; width:500px;margin-top:3rem;">
                            <canvas t-ref="ContractDuration" height="500px" width="500px"/>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
