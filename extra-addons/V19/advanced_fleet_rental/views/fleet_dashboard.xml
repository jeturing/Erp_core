<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--  Record for adding client action on Fleet Dashboard menu  -->
    <record id="action_fleet_dashboard" model="ir.actions.client">
        <field name="name">Fleet Dashboard</field>
        <field name="tag">fleet_dashboard_tag</field>
    </record>
<!--  Adding Fleet menu on Administration   -->
    <menuitem id="menu_fleet_dashboard"
              name="Fleet Dashboard"
              parent="vehicle_management_root"
              action="action_fleet_dashboard"
              sequence="-2"/>
</odoo>
